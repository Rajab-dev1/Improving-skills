#include<iostream>
using namespace std;

class Person
{
protected:
    string name;
    int age;

public:
    Person(string n,int a)
    {
        name=n;
        age=a;
    }
};

class Employee : public Person
{
protected:
    float salary;

public:
    Employee(string n,int a,float s)
    :Person(n,a)
    {
        salary=s;
    }
};

class Manager : public Employee
{
    string department;

public:
    Manager(string n,int a,float s,string d)
    :Employee(n,a,s)
    {
        department=d;
    }

    void display()
    {
        cout<<"Name: "<<name<<endl;
        cout<<"Age: "<<age<<endl;
        cout<<"Salary: "<<salary<<endl;
        cout<<"Department: "<<department<<endl;
    }
};

int main()
{
    Manager m("Ali",35,90000,"IT");
    m.display();

    return 0;
}
